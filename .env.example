# Public application
VITE_SITE_URL=http://localhost:5173
VITE_API_URL=/api
VITE_TURNSTILE_SITE_KEY=

# API
PORT=8787
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/it-boutique
ALLOW_MEMORY_STORE=true
JWT_SECRET=replace-with-at-least-32-random-characters
ADMIN_EMAIL=admin@example.com
# Generate with: node -e "import('bcryptjs').then(b=>b.hash('your-password',12).then(console.log))"
ADMIN_PASSWORD_HASH=
TURNSTILE_SECRET_KEY=
UPLOAD_DIR=./uploads/private
MAX_UPLOAD_MB=8

# Email (optional in local development)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=IT Boutique <hello@example.com>
ADMIN_NOTIFICATION_EMAIL=hello@example.com
